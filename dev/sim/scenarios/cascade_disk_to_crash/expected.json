{
  "description": "Concurrent disk full + myapp stuck",
  "phase_arm": {
    "within_seconds": 240,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(disk|storage|service|process|myapp|cascade)",
        "content_must_mention": ["disk"]
      }
    }
  },
  "phase_dedup": {
    "wait_seconds": 75,
    "assert": { "extra_alerts_max": 2 }
  },
  "phase_disarm": {
    "within_seconds": 180,
    "assert": { "resolution_present_or_silent": true }
  }
}
