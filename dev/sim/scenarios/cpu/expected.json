{
  "description": "All 4 vCPUs saturated by stress-ng matrixprod",
  "phase_arm": {
    "within_seconds": 180,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(cpu|load|high.?load)",
        "content_must_mention": ["cpu"]
      }
    }
  },
  "phase_dedup": {
    "wait_seconds": 75,
    "assert": { "extra_alerts_max": 1 }
  },
  "phase_disarm": {
    "within_seconds": 120,
    "assert": { "resolution_present_or_silent": true }
  }
}
