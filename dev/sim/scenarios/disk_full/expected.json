{
  "description": "/data tmpfs at ~98% (195M of 200M used)",
  "phase_arm": {
    "within_seconds": 180,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(disk|storage|filesystem)",
        "content_must_mention": ["disk"]
      }
    }
  },
  "phase_dedup": {
    "wait_seconds": 75,
    "assert": { "extra_alerts_max": 1 }
  },
  "phase_disarm": {
    "within_seconds": 120,
    "assert": { "resolution_present_or_silent": true }
  }
}
