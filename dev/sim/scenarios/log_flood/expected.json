{
  "description": "/var/log/test.log growing at 100+ MB/min",
  "phase_arm": {
    "within_seconds": 210,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(log|disk|storage|growth)",
        "content_must_mention": ["log"]
      }
    }
  },
  "phase_dedup": {
    "wait_seconds": 75,
    "assert": { "extra_alerts_max": 1 }
  },
  "phase_disarm": {
    "within_seconds": 120,
    "assert": { "resolution_present_or_silent": true }
  }
}
