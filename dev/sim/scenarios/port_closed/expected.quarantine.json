{
  "description": "iptables DROP on 8080 while myapp still runs",
  "phase_arm": {
    "within_seconds": 240,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(port|firewall|network|unreachable|connectivity)",
        "content_must_mention": [
          "8080"
        ]
      }
    }
  },
  "phase_dedup": {
    "wait_seconds": 75,
    "assert": {
      "extra_alerts_max": 1
    }
  },
  "phase_disarm": {
    "within_seconds": 120,
    "assert": {
      "resolution_present_or_silent": true,
      "recovery_probe": "! iptables -C INPUT -p tcp --dport 8080 -j DROP 2>/dev/null"
    }
  },
  "quarantine_reason": "iptables port-drop behavior is not reliable under the gVisor tier2 netstack; run explicitly with --only port_closed or --include-quarantined when validating host netstack support."
}
