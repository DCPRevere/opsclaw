{
  "description": "myapp killed + restarted every 25s",
  "phase_arm": {
    "within_seconds": 210,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(flap|restart|unstable|crash|instab)",
        "content_must_mention": ["myapp"]
      }
    }
  },
  "phase_dedup": {
    "wait_seconds": 75,
    "assert": { "extra_alerts_max": 2 }
  },
  "phase_disarm": {
    "within_seconds": 120,
    "assert": { "resolution_present_or_silent": true }
  }
}
