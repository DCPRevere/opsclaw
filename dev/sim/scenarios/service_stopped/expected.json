{
  "description": "myapp service killed; port 8080 no longer listening",
  "phase_arm": {
    "within_seconds": 180,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(service|process|port|listener|down)",
        "content_must_mention": ["myapp"]
      }
    }
  },
  "phase_dedup": {
    "wait_seconds": 75,
    "assert": { "extra_alerts_max": 1 }
  },
  "phase_disarm": {
    "within_seconds": 120,
    "assert": { "resolution_present_or_silent": true }
  }
}
