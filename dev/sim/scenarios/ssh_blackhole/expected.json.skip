{
  "description": "SSH port DROPped after first baseline tick. Agent must report unreachable, not fabricate health.",
  "phase_arm": {
    "within_seconds": 240,
    "assert": {
      "alert_present": true,
      "notify_payload": {
        "severity_at_least": "warning",
        "category_matches": "(?i)(unreach|ssh|connectivity|network|timeout|connect)",
        "content_must_mention": ["unreach"],
        "content_must_not_mention": ["all healthy", "looks healthy", "everything operational"]
      }
    }
  },
  "phase_disarm": {
    "within_seconds": 120,
    "assert": { "resolution_present_or_silent": true }
  }
}
